  // Yangi test qo'shish (test turlaridan tanlash bilan)
  void _showAddTestDialog(BuildContext context, LanguageProvider lang) {
    final nameController = TextEditingController();
    final priceController = TextEditingController();
    final formKey = GlobalKey<FormState>();
    String? selectedTestTypeId;
    String? selectedTestTypeName;

    showDialog(
      context: context,
      builder: (ctx) => Dialog(
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(24),
          child: Form(
            key: formKey,
            child: StatefulBuilder(
              builder: (context, setDialogState) {
                return Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    // Header
                    Row(
                      children: [
                        Container(
                          padding: const EdgeInsets.all(12),
                          decoration: BoxDecoration(
                            color: Colors.purple.withOpacity(0.1),
                            borderRadius: BorderRadius.circular(12),
                          ),
                          child: const Icon(
                            Icons.science,
                            color: Colors.purple,
                            size: 28,
                          ),
                        ),
                        const SizedBox(width: 16),
                        const Expanded(
                          child: Text(
                            'Yangi Test Qo\'shish',
                            style: TextStyle(
                              fontSize: 20,
                              fontWeight: FontWeight.bold,
                              color: Colors.purple,
                            ),
                          ),
                        ),
                      ],
                    ),
                    const SizedBox(height: 24),

                    // Bemor ismi
                    TextFormField(
                      controller: nameController,
                      decoration: InputDecoration(
                        labelText: 'Bemor ismi *',
                        prefixIcon: const Icon(Icons.person, color: Colors.purple),
                        border: OutlineInputBorder(
                          borderRadius: BorderRadius.circular(12),
                        ),
                        focusedBorder: OutlineInputBorder(
                          borderRadius: BorderRadius.circular(12),
                          borderSide: const BorderSide(color: Colors.purple, width: 2),
                        ),
                      ),
                      validator: (v) => v == null || v.trim().isEmpty
                          ? 'Bemor ismini kiriting'
                          : null,
                    ),
                    const SizedBox(height: 16),

                    // Test turi tanlash
                    StreamBuilder<QuerySnapshot>(
                      stream: FirebaseFirestore.instance
                          .collection('test_types')
                          .orderBy('name')
                          .snapshots(),
                      builder: (context, snapshot) {
                        if (!snapshot.hasData) {
                          return const CircularProgressIndicator();
                        }

                        final testTypes = snapshot.data!.docs;

                        if (testTypes.isEmpty) {
                          return Container(
                            padding: const EdgeInsets.all(16),
                            decoration: BoxDecoration(
                              color: Colors.orange[50],
                              borderRadius: BorderRadius.circular(12),
                              border: Border.all(color: Colors.orange[200]!),
                            ),
                            child: Column(
                              children: [
                                const Text(
                                  'Test turlari yo\'q. Avval test turlarini qo\'shing.',
                                  style: TextStyle(color: Colors.orange),
                                ),
                                const SizedBox(height: 8),
                                TextButton.icon(
                                  onPressed: () {
                                    Navigator.pop(ctx);
                                    _showTestTypesDialog(context);
                                  },
                                  icon: const Icon(Icons.add),
                                  label: const Text('Test Turlari'),
                                ),
                              ],
                            ),
                          );
                        }

                        return DropdownButtonFormField<String>(
                          value: selectedTestTypeId,
                          decoration: InputDecoration(
                            labelText: 'Test turi *',
                            prefixIcon: const Icon(Icons.biotech, color: Colors.purple),
                            border: OutlineInputBorder(
                              borderRadius: BorderRadius.circular(12),
                            ),
                            focusedBorder: OutlineInputBorder(
                              borderRadius: BorderRadius.circular(12),
                              borderSide: const BorderSide(color: Colors.purple, width: 2),
                            ),
                          ),
                          items: testTypes.map((doc) {
                            final data = doc.data() as Map<String, dynamic>;
                            return DropdownMenuItem<String>(
                              value: doc.id,
                              child: Text('${data['name']} - ${data['price']} so\'m'),
                            );
                          }).toList(),
                          onChanged: (value) {
                            setDialogState(() {
                              selectedTestTypeId = value;
                              final selectedDoc = testTypes.firstWhere((doc) => doc.id == value);
                              final data = selectedDoc.data() as Map<String, dynamic>;
                              selectedTestTypeName = data['name'];
                              priceController.text = data['price'].toString();
                            });
                          },
                          validator: (v) => v == null ? 'Test turini tanlang' : null,
                        );
                      },
                    ),
                    const SizedBox(height: 16),

                    // Narx (avtomatik to'ldiriladi)
                    TextFormField(
                      controller: priceController,
                      decoration: InputDecoration(
                        labelText: 'Narx (so\'m) *',
                        prefixIcon: const Icon(Icons.attach_money, color: Colors.purple),
                        border: OutlineInputBorder(
                          borderRadius: BorderRadius.circular(12),
                        ),
                        focusedBorder: OutlineInputBorder(
                          borderRadius: BorderRadius.circular(12),
                          borderSide: const BorderSide(color: Colors.purple, width: 2),
                        ),
                      ),
                      keyboardType: TextInputType.number,
                      readOnly: true,
                      validator: (v) {
                        if (v == null || v.trim().isEmpty) {
                          return 'Narxni kiriting';
                        }
                        if (double.tryParse(v) == null) {
                          return 'To\'g\'ri narx kiriting';
                        }
                        return null;
                      },
                    ),
                    const SizedBox(height: 24),

                    // Tugmalar
                    Row(
                      children: [
                        Expanded(
                          child: OutlinedButton(
                            onPressed: () => Navigator.pop(ctx),
                            style: OutlinedButton.styleFrom(
                              padding: const EdgeInsets.symmetric(vertical: 16),
                              shape: RoundedRectangleBorder(
                                borderRadius: BorderRadius.circular(12),
                              ),
                            ),
                            child: const Text('Bekor qilish'),
                          ),
                        ),
                        const SizedBox(width: 12),
                        Expanded(
                          flex: 2,
                          child: ElevatedButton.icon(
                            onPressed: () async {
                              if (!formKey.currentState!.validate()) return;

                              try {
                                await FirebaseFirestore.instance
                                    .collection('laboratory_tests')
                                    .add({
                                  'patientName': nameController.text.trim(),
                                  'testType': selectedTestTypeName,
                                  'testTypeId': selectedTestTypeId,
                                  'price': double.parse(priceController.text.trim()),
                                  'status': 'pending',
                                  'isPaid': false,
                                  'result': null,
                                  'createdAt': FieldValue.serverTimestamp(),
                                  'createdBy': FirebaseAuth.instance.currentUser?.uid,
                                });

                                if (ctx.mounted) {
                                  Navigator.pop(ctx);
                                  ScaffoldMessenger.of(context).showSnackBar(
                                    const SnackBar(
                                      content: Row(
                                        children: [
                                          Icon(Icons.check_circle, color: Colors.white),
                                          SizedBox(width: 12),
                                          Text('Test muvaffaqiyatli qo\'shildi!'),
                                        ],
                                      ),
                                      backgroundColor: Colors.green,
                                    ),
                                  );
                                }
                              } catch (e) {
                                if (ctx.mounted) {
                                  ScaffoldMessenger.of(context).showSnackBar(
                                    SnackBar(
                                      content: Text('Xatolik: $e'),
                                      backgroundColor: Colors.red,
                                    ),
                                  );
                                }
                              }
                            },
                            icon: const Icon(Icons.save),
                            label: const Text('Saqlash'),
                            style: ElevatedButton.styleFrom(
                              padding: const EdgeInsets.symmetric(vertical: 16),
                              backgroundColor: Colors.purple,
                              foregroundColor: Colors.white,
                              shape: RoundedRectangleBorder(
                                borderRadius: BorderRadius.circular(12),
                              ),
                            ),
                          ),
                        ),
                      ],
                    ),
                  ],
                );
              },
            ),
          ),
        ),
      ),
    );
  }

